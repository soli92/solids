{
  "$schema": "https://ui.shadcn.com/schema.json",
  "registries": {
    "@solids": {
      "url": "https://raw.githubusercontent.com/Soli92/solids/main/registry/r/{name}.json"
    }
  },
  "style": "new-york",
  "rsc": false,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.cjs",
    "css": ".storybook/preview-tw.input.css",
    "baseColor": "slate",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  }
}
