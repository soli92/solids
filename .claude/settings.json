{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "REPO_ROOT": "${CLAUDE_PROJECT_DIR}"
  },
  "permissions": {
    "allow": [],
    "additionalDirectories": []
  },
  "hooks": {
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/tools/analytics/harvest-session-tokens.py\" --from-hook --project solids 2>/dev/null || true",
            "timeout": 30,
            "statusMessage": "Analytics: harvest token usage (EP-013 dogfooding)"
          }
        ]
      }
    ]
  }
}
