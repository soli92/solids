{
  "$schema": "https://ui.shadcn.com/schema.json",
  "registries": {
    "@solids": {
      "url": "https://raw.githubusercontent.com/soli92/solids/main/registry/r/{name}.json"
    }
  },
  "style": "new-york",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "tailwind.config.ts",
    "css": "app/globals.css",
    "baseColor": "slate",
    "cssVariables": true
  },
  "iconLibrary": "lucide",
  "aliases": {
    "components": "@/components",
    "utils": "@/lib/utils",
    "ui": "@/components/ui",
    "lib": "@/lib",
    "hooks": "@/hooks"
  }
}
