{
  "name": "@soli92/solids",
  "version": "1.6.0",
  "description": "SoliDS – agnostic design system foundations (tokens + CSS) with shadcn/ui compatibility.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soli92/solids.git"
  },
  "homepage": "https://github.com/soli92/solids#readme",
  "bugs": {
    "url": "https://github.com/soli92/solids/issues"
  },
  "keywords": [
    "design-system",
    "tokens",
    "css-variables",
    "shadcn",
    "shadcn-ui",
    "tailwind",
    "solids"
  ],
  "sideEffects": false,
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "default": "./dist/tokens/tokens.json"
    },
    "./tokens": "./dist/tokens/tokens.json",
    "./css/index.css": "./dist/css/index.css",
    "./css/variables.css": "./dist/css/variables.css",
    "./css/themes.css": "./dist/css/themes.css",
    "./css/shadcn.css": "./dist/css/shadcn.css",
    "./css/base.css": "./dist/css/base.css",
    "./css/utilities.css": "./dist/css/utilities.css",
    "./tailwind-preset": "./dist/tailwind/preset.cjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "clean": "node -e \"import('node:fs').then(({rmSync})=>rmSync('dist',{recursive:true,force:true}))\"",
    "prepublishOnly": "npm run build",
    "release": "semantic-release",
    "build:storybook-css": "tailwindcss -c ./tailwind.config.cjs -i ./.storybook/preview-tw.input.css -o ./.storybook/preview-tw.built.css",
    "ui:stories": "node ./scripts/generate-ui-stories.mjs",
    "storybook": "npm run build && npm run build:storybook-css && npm run ui:stories && storybook dev -p 6006",
    "build-storybook": "npm run build && npm run build:storybook-css && npm run ui:stories && storybook build && node ./scripts/inject-storybook-base.mjs",
    "registry:sync": "node ./scripts/sync-registry.mjs",
    "registry:build": "node ./scripts/sync-registry.mjs && shadcn build --output ./registry/r",
    "test": "npm run build && npm run build-storybook"
  },
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/commit-analyzer": "^13.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/github": "^10.0.0",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.0.0",
    "@storybook/addon-docs": "^8.6.14",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.3.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-day-picker": "^9.14.0",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.0",
    "react-resizable-panels": "^4.7.5",
    "recharts": "^2.15.4",
    "semantic-release": "^25.0.0",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "storybook": "^8.6.14",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.2",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  }
}
